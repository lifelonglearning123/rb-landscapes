# GoHighLevel direct API integration.
# Location ID: Settings > Business Profile (or the URL after /location/).
# Private Integration Token: Settings > Private Integrations (needs
# contacts.write + contacts.readonly scopes). Keep the real values in
# .env.local (gitignored) — never commit them.
GHL_LOCATION_ID=your-location-id
GHL_PRIVATE_TOKEN=pit-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Public site URL (used for sitemap + canonical tags)
NEXT_PUBLIC_SITE_URL=https://www.rblandscapesanddriveways.com

# GHL calendar embed URL (Calendars > your calendar > Share > Embed link)
NEXT_PUBLIC_GHL_CALENDAR_URL=
